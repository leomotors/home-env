{
    "swagger": "2.0",
    "info": {
        "description": "Home environment sensor monitoring API",
        "title": "Home Env API",
        "contact": {},
        "version": "3.1.0"
    },
    "host": "localhost:8939",
    "basePath": "/",
    "paths": {
        "/data": {
            "get": {
                "description": "Returns the latest temperature and humidity readings from all sensors",
                "produces": [
                    "application/json"
                ],
                "summary": "Get all sensor data",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/DataResponse"
                        }
                    }
                }
            }
        },
        "/update": {
            "post": {
                "description": "Receives temperature and humidity data from an ESP32 sensor. Local network only.",
                "consumes": [
                    "application/json"
                ],
                "summary": "Update sensor data",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Password for authentication",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Sensor reading data",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/UpdateRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted"
                    },
                    "400": {
                        "description": "Invalid request body or values out of range"
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "404": {
                        "description": "Sensor not found"
                    }
                }
            }
        }
    },
    "definitions": {
        "DataResponse": {
            "type": "object",
            "required": [
                "sensors"
            ],
            "properties": {
                "sensors": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/SensorDetail"
                    }
                }
            }
        },
        "SensorDetail": {
            "type": "object",
            "required": [
                "id",
                "lastUpdated",
                "name",
                "online"
            ],
            "properties": {
                "humidity": {
                    "type": "number",
                    "example": 48.2
                },
                "id": {
                    "type": "string",
                    "example": "main_room"
                },
                "lastUpdated": {
                    "type": "number",
                    "example": 2.14
                },
                "name": {
                    "type": "string",
                    "example": "Office Room"
                },
                "online": {
                    "type": "boolean",
                    "example": true
                },
                "temperature": {
                    "type": "number",
                    "example": 25.5
                }
            }
        },
        "UpdateRequest": {
            "type": "object",
            "required": [
                "humidity",
                "sensorId",
                "temperature"
            ],
            "properties": {
                "humidity": {
                    "type": "number",
                    "example": 50
                },
                "sensorId": {
                    "type": "string",
                    "example": "main_room"
                },
                "temperature": {
                    "type": "number",
                    "example": 24.5
                }
            }
        }
    }
}